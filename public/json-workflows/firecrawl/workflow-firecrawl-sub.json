    {
      "parameters": {
        "promptType": "define",
        "text": "=Markdown: {{ $json.data.markdown }}",
        "options": {
          "systemMessage": "=You are a product data extraction specialist. Analyze the provided markdown content from e-commerce product pages.\n\nAlways respond ONLY with valid JSON in this exact format:\n{\n  \"product_title\": \"string - full product name\",\n  \"competitor_price\": number - current price without currency symbol,\n  \"in_stock\": boolean - true if available for purchase\n}\n\nPRICE RULES:\n- Extract only the number (e.g., 199.99 not \"$199.99\")\n- Use the current/sale price, NOT the original \"Comp. Value\" price\n- If you see \"$199.99 Save $20 Comp. Value: $219.99\" - use 199.99\n\nIN_STOCK RULES:\n- TRUE if you see ANY of these:\n  * \"Add to Cart\" button\n  * \"Pickup Ready within X hour\"\n  * \"Get it Tomorrow\" or shipping date\n  * \"Only X left at your store\"\n  * \"Shipping available\"\n  \n- FALSE ONLY if you see:\n  * \"Out of Stock\"\n  * \"Sold Out\" \n  * \"Currently Unavailable for Purchase\"\n  * \"This item is not available\"\n\n- IGNORE \"Unavailable\" next to Save/Wishlist buttons - this is NOT about stock status\n- If pickup OR shipping options are shown with dates/times = TRUE\n\nDo not include any explanation or anything outside the json output such as '''json, only the JSON output."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        416,
        352
      ],
      "id": "0e3bf8da-1aac-4af8-b882-ed51519ced4f",
      "name": "Extraction Agent"
    },
    {
      "parameters": {
        "operation": "set",
        "key": "=price_cache:{{ $('When Executed by Another Workflow').item.json.Link }}",
        "value": "={{ $json.output }}",
        "expire": true,
        "ttl": 21600
      },
      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [
        688,
        352
      ],
      "id": "101704b2-04bb-4d59-8b60-e18609aef70b",
      "name": "Save Data in Redis",
      "credentials": {
        "redis": {
          "id": "DTel7RAIIZmszinX",
          "name": "redis-api-ssmith1975.ai"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const cleanJSON = (raw) => \n  raw.replace(/^```json\\s*/i, \"\")  // remove leading ```json + newline/spaces\n  .replace(/```$/i, \"\")         // remove trailing ``` \n  .trim();\n\n// Get the data sent from the parent workflow (the one that called this subworkflow)\nconst rootData = $('When Executed by Another Workflow').first().json;\n\n// Extract and convert \"Our Price\" (which comes in as text) into a number\nconst ourPrice = parseFloat(rootData[\"Our Price\"]); \nconst cleanInput = cleanJSON($input.first().json.output);\n\n\n// Parse the AI agent’s JSON output (stored as a text string) into a real JavaScript object\nconst aiResponse = JSON.parse(cleanInput); //JSON.parse($json.output);\n\n// Extract and convert the competitor’s price into a number\nconst competitorPrice = parseFloat(aiResponse.competitor_price);\n\n// Calculate the price difference between your price and the competitor’s\nconst priceDiff = ourPrice - competitorPrice;\n\n// Calculate what percentage difference that is, rounded to one decimal place\nconst priceDiffPercent = ((priceDiff / ourPrice) * 100).toFixed(1);\n\n// Return a new JSON object containing all the useful information\n// n8n will pass this object to the next node in the workflow\nreturn {\n  json: {\n    // Product title returned from the AI agent\n    product_title: aiResponse.product_title,\n    // Whether the product is in stock (true/false or text)\n    in_stock: aiResponse.in_stock,\n    // Your own price\n    our_price: ourPrice,\n    // The competitor’s price\n    competitor_price: competitorPrice,\n    // The numeric price difference (in dollars)\n    price_difference: priceDiff,\n    // The percentage difference, shown as a string with %\n    price_diff_percent: `${priceDiffPercent}%`\n  }\n};\n\n\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        864,
